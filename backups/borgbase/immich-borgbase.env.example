# Copy to /etc/borgbase/immich.env on the OVH server and edit there.
# Do not commit the real /etc/borgbase/immich.env if it contains a private repo URL.

# Absolute path to this Immich docker compose checkout.
IMMICH_APP_DIR="/home/terrance/immich-app"

# Absolute path to Immich's UPLOAD_LOCATION on the host.
# In this repo's default compose setup, .env uses UPLOAD_LOCATION=./library.
UPLOAD_LOCATION="/home/terrance/immich-app/library"

# Immich Postgres settings.
DB_CONTAINER="immich_postgres"
DB_USERNAME="postgres"

# BorgBase repository URL copied from BorgBase, for example:
# BORG_REPO="ssh://xxxx@xxxx.repo.borgbase.com/./repo"
BORG_REPO=""

# Private SSH key created on this server for BorgBase.
BORG_KEY_FILE="/root/.ssh/immich_borgbase"

# Root-only file containing the Borg repository passphrase.
BORG_PASSPHRASE_FILE="/etc/borgbase/immich-passphrase"

# Optional lock file. Leave unset for /var/lock as root, or /tmp for a user-level setup.
# LOCK_FILE="/var/lock/immich-borgbase-backup.lock"

# Retention policy.
BORG_KEEP_DAILY="7"
BORG_KEEP_WEEKLY="4"
BORG_KEEP_MONTHLY="12"

# Space-separated paths, relative to UPLOAD_LOCATION, to exclude from Borg.
BORG_EXCLUDE_RELATIVE="thumbs encoded-video"
